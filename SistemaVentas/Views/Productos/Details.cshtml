@model SistemaVentas.Models.ProductoModel

@{
    ViewData["Title"] = "Detalle del Producto";
}

<h2>Detalle del Producto</h2>

<dl class="row">
    <dt class="col-sm-3">Nombre</dt>
    <dd class="col-sm-9">@Model.nombre</dd>

    <dt class="col-sm-3">Descripción</dt>
    <dd class="col-sm-9">@Model.descripcion</dd>

    <dt class="col-sm-3">Precio</dt>
    <dd class="col-sm-9">@Model.precio.ToString("C")</dd>

    <dt class="col-sm-3">Stock</dt>
    <dd class="col-sm-9">@Model.stock</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.producto_id" class="btn btn-warning">Editar</a>
<a asp-action="Index" class="btn btn-secondary">Volver</a>
